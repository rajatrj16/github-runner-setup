# =============================================================================
# GitHub Self-Hosted Runner Configuration
# =============================================================================
# Copy this file to runner-config.env and fill in your values.
# Usage: cp runner-config.example.env runner-config.env
# =============================================================================

# -----------------------------------------------------------------------------
# GitHub Authentication
# -----------------------------------------------------------------------------
# Personal Access Token with admin:org (org runners) or repo (repo runners) scope.
# Used as fallback if GitHub CLI (gh) is not available.
# Leave empty to use gh CLI or manual token entry.
GITHUB_PAT=""

# -----------------------------------------------------------------------------
# Runner Scope - Choose ONE of the following sections
# -----------------------------------------------------------------------------

# --- Option A: Organization-level runner ---
# RUNNER_SCOPE="org"
# GITHUB_ORG="my-organization"

# --- Option B: Repository-level runner ---
# RUNNER_SCOPE="repo"
# GITHUB_REPO="owner/repository-name"

# -----------------------------------------------------------------------------
# Runner Configuration
# -----------------------------------------------------------------------------
# Name prefix for the runner (hostname will be appended automatically)
RUNNER_NAME_PREFIX="runner"

# Comma-separated labels to assign to the runner
# Example: "self-hosted,linux,x64,production"
RUNNER_LABELS="self-hosted"

# Runner group (org-level only, leave empty for 'Default')
RUNNER_GROUP=""

# Working directory for runner job execution
RUNNER_WORK_DIR="_work"

# -----------------------------------------------------------------------------
# VM Capacity Limits
# -----------------------------------------------------------------------------
# Maximum number of runner instances allowed on this VM.
# Leave empty to auto-calculate based on CPU, RAM, and disk.
# Formula: min(CPU_CORES/2, TOTAL_RAM_GB/2, FREE_DISK_GB/10)
MAX_RUNNERS=""

# -----------------------------------------------------------------------------
# Installation Paths
# -----------------------------------------------------------------------------
# Base directory where runner instances are installed
# Linux default: /opt/github-runners
# Windows default: C:\github-runners
RUNNER_INSTALL_DIR=""
